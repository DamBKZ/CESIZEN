# =============================================================================
# STAGE 1 — BUILD
# =============================================================================
FROM eclipse-temurin:21-jdk AS build

WORKDIR /app

# Copie séparée du pom.xml et téléchargement des dépendances en premier
# — exploite le cache Docker : si le code change mais pas le pom.xml,
#   Maven ne re-télécharge pas toutes les dépendances
COPY pom.xml ./
COPY .mvn .mvn
COPY mvnw ./
RUN ./mvnw -q dependency:go-offline

COPY src ./src
RUN ./mvnw -q -DskipTests package

# =============================================================================
# STAGE 2 — RUN
# =============================================================================
FROM eclipse-temurin:21-jre

WORKDIR /app

# Utilisateur non-root pour limiter les risques en cas de compromission
RUN addgroup --system cesizen && adduser --system --ingroup cesizen cesizen
USER cesizen

COPY --from=build /app/target/*.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]